# CV Reviewer Backend - Environment Variables Example
# Copy this file to .env and fill in real values
# NEVER commit .env to version control

# DeepSeek API Key (required for CV analysis)
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Session TTL in minutes (how long a session stays alive without activity)
SESSION_TTL_MINUTES=60

# Maximum file size in MB for uploaded CVs
MAX_FILE_SIZE_MB=10

# Maximum Job Description length in characters
MAX_JD_LENGTH=5000

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173

# Backend server port
PORT=8000
